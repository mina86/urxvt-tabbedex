post_install () {
	echo "==> To enable tabbedex, place the following line in your X resources file"
	echo "==>     URxvt.perl-ext-common:  default,tabbedex"
	echo "==> If you don't have an X resources file set up, check the wiki."
	echo "==> For documentation see the urxvt-tabbedex man page."
}

post_upgrade () {
	post_install
}
